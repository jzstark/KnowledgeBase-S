# 数据库
DB_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/app

# Claude API（摘要 + 标签提取）
CLAUDE_API_KEY=sk-ant-...

# OpenAI API（embedding，text-embedding-3-small）
OPENAI_API_KEY=sk-...

# 认证（单用户模式）
AUTH_PASSWORD=change_me
AUTH_SECRET=random_32_char_string_change_me_x
# Optional. Set to .example.com when auth must work across subdomains.
AUTH_COOKIE_DOMAIN=

# 应用
NEXTAUTH_URL=https://kb.yourdomain.com

# Wechat2RSS（微信公众号订阅，托管在独立 RSS VPS）
WECHAT2RSS_BASE_URL=https://rss.laughtale.co.uk/wechat-api
WECHAT2RSS_FEED_BASE_URL=https://rss.laughtale.co.uk/wechat
WECHAT2RSS_TOKEN=change_me_wechat2rss_token

# GitHub Container Registry（构建镜像时用）
GITHUB_OWNER=your_github_username

# LibreChat（独立 agent 聊天 UI，运行在子域名 chat.laughtale.co.uk，通过 kb-mcp 接入知识库）
# 生成秘钥：openssl rand -hex 16（IV/Meili）/ openssl rand -hex 32（JWT/CREDS）
MEILI_MASTER_KEY=change_me_meili
LIBRECHAT_JWT_SECRET=change_me_lc_jwt
LIBRECHAT_JWT_REFRESH_SECRET=change_me_lc_refresh
LIBRECHAT_CREDS_KEY=change_me_creds_key
LIBRECHAT_CREDS_IV=change_me_creds_iv
# 公开域名，用于 OAuth/重定向
LIBRECHAT_DOMAIN_CLIENT=https://chat.laughtale.co.uk
LIBRECHAT_DOMAIN_SERVER=https://chat.laughtale.co.uk
