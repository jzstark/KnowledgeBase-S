# 数据库
DB_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/app

# Claude API（摘要 + 标签提取）
CLAUDE_API_KEY=sk-ant-...

# OpenAI API（embedding，text-embedding-3-small）
OPENAI_API_KEY=sk-...

# 认证（单用户模式）
AUTH_PASSWORD=change_me
AUTH_SECRET=random_32_char_string_change_me_x

# 应用
NEXTAUTH_URL=https://kb.yourdomain.com

# Wechat2RSS（微信公众号订阅）
WECHAT2RSS_LIC_EMAIL=your_email@example.com
WECHAT2RSS_LIC_CODE=your_activation_code
WECHAT2RSS_TOKEN=change_me_wechat2rss_token
WECHAT2RSS_RSS_HOST=wechat2rss.yourdomain.com
WECHAT2RSS_RSS_HTTPS=1

# GitHub Container Registry（构建镜像时用）
GITHUB_OWNER=your_github_username
