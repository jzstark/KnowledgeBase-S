# 数据库
DB_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/app

# Claude API（摘要 + 标签提取）
CLAUDE_API_KEY=sk-ant-...

# OpenAI API（embedding，text-embedding-3-small）
OPENAI_API_KEY=sk-...

# 认证（单用户模式）
AUTH_PASSWORD=change_me
AUTH_SECRET=random_32_char_string_change_me_x
# Optional. Set to .example.com when auth must work across subdomains.
AUTH_COOKIE_DOMAIN=
# Optional service token for read-only kb-chat/kb-mcp access to selected KB endpoints.
# Generate a strong value before enabling; blank disables service-token auth.
KB_SERVICE_TOKEN=
# Inbound auth for the public MCP endpoint (/mcp, streamable-http). Callers must
# present this via X-MCP-Token or Bearer. Blank => kb-mcp rejects every request
# (fail closed). Use a strong random value distinct from KB_SERVICE_TOKEN.
MCP_STATIC_TOKEN=
# Optional CORS allowlist (comma-separated origins) for genuine cross-origin
# callers. The web UI is same-origin via the Next.js rewrite and needs nothing
# here; defaults to NEXTAUTH_URL when blank. Never use "*" with credentials.
CORS_ALLOW_ORIGINS=
# Optional login brute-force throttle (per client IP). Defaults shown.
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_SECONDS=300

# 应用
NEXTAUTH_URL=https://kb.yourdomain.com

# Wechat2RSS（微信公众号订阅，托管在独立 RSS VPS）
WECHAT2RSS_BASE_URL=https://rss.laughtale.co.uk/wechat-api
WECHAT2RSS_FEED_BASE_URL=https://rss.laughtale.co.uk/wechat
WECHAT2RSS_TOKEN=change_me_wechat2rss_token

# GitHub Container Registry（构建镜像时用）
GITHUB_OWNER=your_github_username
